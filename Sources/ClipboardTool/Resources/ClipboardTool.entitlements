<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox — required for App Store, enabled from day 1 -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Clipboard read access -->
    <key>com.apple.security.temporary-exception.sbpl</key>
    <array>
        <string>(allow user-preference-read (preference-domain "com.apple.universalaccess"))</string>
    </array>

    <!-- Outgoing network (needed by Sparkle for update checks) -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
